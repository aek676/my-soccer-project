{
	"name": "bun-backend",
	"version": "1.0.50",
	"scripts": {
		"test": "bun test",
		"build": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun --outfile dist/server src/index.ts",
		"start": "NODE_ENV=production ./dist/server",
		"dev": "bun run --watch src/server.ts",
		"typecheck": "bun tsc",
		"lint": "biome check --write"
	},
	"dependencies": {
		"@elysia/jwt": "^1.4.2",
		"@elysia/openapi": "^1.4.15",
		"elysia": "^1.4.28",
		"elysia-healthcheck": "^1.0.0",
		"mongoose": "^9.6.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@testcontainers/mongodb": "^11.14.0",
		"bun-types": "latest",
		"testcontainers": "^11.14.0",
		"typescript": "^6.0.3"
	},
	"module": "src/index.js",
	"trustedDependencies": [
		"protobufjs"
	]
}
